# Kamal reads these at deploy time. Keep lines SIMPLE — the parser is not a
# shell, so no ${VAR:-default} and no pipes (see error #4 in the playbook).
#
# This stateless app needs only the registry password to pull/push the image:
#   - In CI: KAMAL_REGISTRY_PASSWORD is the runner's GITHUB_TOKEN.
#   - Locally: export a ghcr PAT with write:packages before `kamal deploy`.
KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD
